# yuque2git 环境变量配置
# 请根据实际情况修改以下值

# === 必需配置 ===
# 语雀 API Token（从语雀个人设置获取）
export YUQUE_TOKEN=""

# 文档输出目录（Git 仓库根目录）
export OUTPUT_DIR="/home/admin/yuque-docs"

# === 可选配置 ===
# 推送决策模式：llm（本机LLM判定）或 openclaw（OpenClaw回调判定）
export PUSH_DECISION_MODE="llm"

# === OpenClaw 模式（当 PUSH_DECISION_MODE=openclaw 时）===
# export OPENCLAW_CALLBACK_URL="http://gateway:13040/hooks/agent"
# export OPENCLAW_HOOKS_TOKEN=""
# export YUQUE2GIT_PUBLIC_URL="http://your-host:8765"
# 投递 Agent 回复到 QQ：channel 填 qq，to 填群ID或用户ID
# export YUQUE2GIT_DELIVER_CHANNEL="qq"
# export YUQUE2GIT_DELIVER_TO="1179350197"
# 多目标时两次 POST 间隔（秒），默认 2；遇 429 时重试次数，默认 3
# export YUQUE2GIT_DELIVER_DELAY_SECONDS="2"
# export YUQUE2GIT_DELIVER_MAX_RETRIES="3"
# 自定义发给 Agent 的 message 模板（占位符见 SKILL.md）
# export YUQUE2GIT_OPENCLAW_MESSAGE_TEMPLATE=""

# === LLM 模式配置（当 PUSH_DECISION_MODE=llm 时）===
# OpenAI API Key（或使用其他兼容API）
export OPENAI_API_KEY=""
# OpenAI API 基地址（可选，默认 https://api.openai.com/v1）
# export OPENAI_BASE_URL="https://api.openai.com/v1"
# 模型（可选，默认 gpt-4o-mini）
# export OPENAI_MODEL="gpt-4o-mini"

# === 推送通知配置 ===
# 推送通知 URL（可选）
# export NOTIFY_URL=""

# === 邮件推送配置（全部设置后启用）===
# export SMTP_HOST=""
# export SMTP_PORT="587"
# export SMTP_USER=""
# export SMTP_PASSWORD=""
# export EMAIL_FROM=""
# export EMAIL_TO=""

# === 其他可选配置 ===
# 是否在推送后自动 git push（默认 false）
# export GIT_PUSH_ON_PUSH="false"
# 是否只对比正文 diff（默认 true，省 token）
# export ENABLE_BODY_ONLY_DIFF="true"
# 是否生成更新摘要（默认 true）
# export ENABLE_UPDATE_SUMMARY="true"
